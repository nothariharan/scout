# Add real values only to an untracked .env file at the repo root.
# The orchestrator auto-loads this file at startup (node src/server/start.js).
# Do not put call recordings, API keys, or user documents in source control.
# Each integration activates the moment its key is present; all have safe
# fallbacks so the pipeline runs keyless for demos and tests.

ELEVENLABS_API_KEY=
ELEVENLABS_INTAKE_AGENT_ID=
ELEVENLABS_NEGOTIATOR_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=
TELEPHONY_PROVIDER=
TELEPHONY_ACCOUNT_SID=
TELEPHONY_AUTH_TOKEN=
MAPS_API_KEY=
DATABASE_URL=

# Backend (orchestrator) — optional; pipeline runs without these via fallbacks.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TAVILY_API_KEY=
GOOGLE_PLACES_API_KEY=
PORT=8787
# Optional: persist orchestrator state to this JSON file (survives restarts).
SCOUT_STATE_FILE=

