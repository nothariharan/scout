  "negotiation_policy": { "max_counter_rounds": { "aggressive": 3, "balanced": 2, "fast": 1 }, "target_discount_percent": { "aggressive": 12, "balanced": 7, "fast": 3 }, "allow_tradeables": ["warranty_months", "materials", "timeline_days"], "truthful_leverage_only": true, "never_commit_funds": true },
  "fraud_rules": [
    { "id": "large_upfront_payment", "trigger_keywords": ["full payment upfront", "pay everything before work", "100 percent advance"], "action": "flag_high_risk" },
    { "id": "cash_no_invoice", "trigger_keywords": ["cash only", "no invoice", "without bill"], "action": "flag_high_risk" },
    { "id": "no_warranty", "trigger_keywords": ["no warranty", "no guarantee"], "action": "flag_caution" },
    { "id": "vague_scope", "trigger_keywords": ["final after work", "we will see later", "not included"], "action": "flag_caution" }
  ],
  "seller_personas": ["transparent_contractor", "fee_padder", "busy_high_quote", "unsafe_upfront_payment"]
}
